<Window x:Class="Skymu.Options"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Skymu.Properties"
        xmlns:local="clr-namespace:Skymu"
        mc:Ignorable="d"
        FontFamily="Tahoma"
        Title="{Binding Source={x:Static properties:Settings.Default},
                      Path=BrandingName,
                      StringFormat={}{0}™ - Options}" ResizeMode="CanMinimize" Height="610" Width="718" WindowStartupLocation="CenterScreen" HorizontalAlignment="Left" VerticalAlignment="Top">
    <Window.Resources>
        <local:ThemeImageConverter x:Key="ThemeImageConverter"/>
    </Window.Resources>

        <Grid Background="#d4e2f2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="195"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
            <local:SliceControlSource="{Binding Source={x:Static properties:Settings.Default},                 Path=ThemeRoot,                 Converter={StaticResource ThemeImageConverter}, ConverterParameter='Options/header.png'}"ElementCount="5"                          StackDirection="Vertical"DefaultIndex="1"Margin="9,9,9,0"   HoverIndex="-1"PressedIndex="-1"IsHitTestVisible="False"TextStartPositionX="13"Text="Advanced"                                TextFont="Tahoma"TextSize="11"TextColor="#666666"HorizontalAlignment="Stretch" />


            <ListBox Margin="9,0,9,0" BorderThickness="1,0,1,1" BorderBrush="#26000000">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Foreground" Value="#FF6E6E73"/>
                            <Setter Property="Height" Value="38"/>
                            <Setter Property="Padding" Value="8,1,8,1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Name="Border"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#84c0fc"/>
                                                <Setter Property="Foreground" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Resources>

                    <ListBoxItem Content="Placeholder1" IsSelected="True"/>
                    <ListBoxItem Content="Placeholder2"/>
                </ListBox>

            </StackPanel>
            <Grid Grid.Column="1" Margin="-4,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="59*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <local:SliceControl                            Grid.ColumnSpan="2"Source="{Binding Source={x:Static properties:Settings.Default},                 Path=ThemeRoot,                 Converter={StaticResource ThemeImageConverter}, ConverterParameter='Options/header.png'}"ElementCount="5"                             StackDirection="Vertical"DefaultIndex="1"Margin="0,9,9,0"      HoverIndex="-1"PressedIndex="-1"IsHitTestVisible="False"TextStartPositionX="13"Text="Skymu Customization"                                TextFont="Tahoma"TextWeight="Bold"TextSize="11"TextColor="#666666"HorizontalAlignment="Stretch" />



            <Border x:Name="OptionCategoryContainer" Grid.Row="1" Grid.ColumnSpan="2"  BorderBrush="#26000000"
 BorderThickness="1,0,1,1" Background="White" Margin="0,0,9,45">
                    <!--<StackPanel Orientation="Vertical" Margin="8,8,8,8">

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Use port" VerticalAlignment="Center" Width="80"/>
                            <TextBox Width="80"/>
                            <TextBlock Text="for incoming connections" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <CheckBox Content="Use port 80 and 443 for additional incoming connections" IsChecked="True" Margin="0,5"/>

                        <ComboBox Width="250" Margin="0,10">
                            <ComboBoxItem Content="Automatic proxy detection" IsSelected="True"/>
                            <ComboBoxItem Content="HTTPS proxy"/>
                            <ComboBoxItem Content="SOCKS proxy"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Host" Width="80"/>
                            <TextBox Width="150"/>
                            <TextBlock Text="Port" Margin="10,0,0,0" Width="40"/>
                            <TextBox Width="80"/>
                        </StackPanel>

                        <CheckBox Content="Enable proxy authentication" Margin="0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Username" Width="80"/>
                            <TextBox Width="150"/>
                            <TextBlock Text="Password" Margin="10,0,0,0" Width="60"/>
                            <TextBox Width="150"/>
                        </StackPanel>

                    </StackPanel>-->

                    <WrapPanel MouseLeftButtonDown="CarouselGrid_MouseLeftButtonDown">
                        <Label Content="This options menu provides you with an easy way to modify your Skymu-specific preferences." FontFamily="Tahoma"  Margin="8,8,0,0" FontSize="11"/>
                        <Grid x:Name="CarouselGrid">
                            <Canvas x:Name="CarouselCanvas" ClipToBounds="True" Height="300" Width="579" />
                    </Grid>
                    </WrapPanel>
                </Border>


                <StackPanel Grid.Row="1" Orientation="Horizontal" Grid.Column="1" Margin="0,0,9,11" RenderTransformOrigin="0.362,-3.031" HorizontalAlignment="Right" Width="156" Height="23" VerticalAlignment="Bottom">
                    <Button Content="Save" Height="23" Width="73" Margin="0,0,10,0" FontSize="11"/>
                    <Button Content="Cancel" Height="23" Width="73" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Grid>

</Window>
