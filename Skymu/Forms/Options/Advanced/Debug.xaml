<Page
    x:Class="Skymu.Forms.OptionPages.Advanced.Debug"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:global="clr-namespace:Skymu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:preferences="clr-namespace:Skymu.Preferences"
    xmlns:theming="clr-namespace:Skymu.Theming"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    d:Background="#FFFFFF"
    d:Height="505"
    d:Width="514"
    DataContext="{StaticResource Lang}"
    FontFamily="Tahoma"
    FontSize="11"
    Foreground="{DynamicResource Text.VeryHighContrast}"
    Style="{StaticResource Page}"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:AssetLoader x:Key="AssetLoader" />
    </Page.Resources>

    <Grid Margin="15,20,15,35">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical">
            <CheckBox
                Margin="0,5"
                Content="Separate credentials between debug and release build"
                IsChecked="{Binding Path=[SeparateCredentialsForDebug], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />
            <Grid Margin="0,5" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Text="Absolute path to load plugins from"
                    VerticalAlignment="Center" />
                <TextBox
                    x:Name="PluginPathBox"
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Text="{Binding Path=[CustomPluginPath], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />
                <Button
                    Grid.Column="2"
                    Margin="5,0,0,0"
                    Padding="10,0"
                    Click="PluginPathBrowseClick"
                    Content="Browse..." />
            </Grid>
            <TextBlock
                Margin="0,-5"
                Grid.Column="0"
                Foreground="{StaticResource Text.MediumContrast}"
                Text="Hint: Set it to (Skymu source)\Plugins\bin to ease plugin development"
                VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            VerticalAlignment="Bottom"
            Orientation="Vertical">
            <TextBlock Foreground="{DynamicResource Text.Highlight}" Text="{Binding Path='[sF_OPTIONS_LBC_OTHER]', Source={StaticResource Lang}}" />
            <Separator Margin="0,10,0,10" Foreground="{DynamicResource Separator}" />
            <!--  Do NOT use SliceControl here. Accurately, the image is unclickable.  -->
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding Converter={StaticResource AssetLoader}, Source=Assets/Universal/Options/connection.png}" />
                <TextBlock Margin="15,0,0,0" VerticalAlignment="Center">
                    <Hyperlink NavigateUri="{Binding Source={x:Static global:Universal.GITHUB_PULLS_URL}}" RequestNavigate="OURL">Contribute to Skymu</Hyperlink>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
